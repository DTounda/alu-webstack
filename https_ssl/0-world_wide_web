#!/usr/bin/env bash
# Displays DNS A record information for subdomains of a given domain
# shellcheck disable=SC2086

lookup() {
    local raw
    raw=$(dig "$1" +noall +answer)
    echo "DEBUG raw='$raw'" >&2
    echo "$raw" | awk '{print $4, $5}'
}

d="$1"
s="$2"

if [ -n "$s" ]; then
    result=$(lookup "$s.$d")
    echo "DEBUG result='$result'" >&2
    type=$(echo $result | awk '{print $1}')
    dest=$(echo $result | awk '{print $2}')
    echo "The subdomain $s is a $type record and points to $dest"
else
    for name in www lb-01 web-01 web-02; do
        result=$(lookup "$name.$d")
        echo "DEBUG result='$result'" >&2
        type=$(echo $result | awk '{print $1}')
        dest=$(echo $result | awk '{print $2}')
        echo "The subdomain $name is a $type record and points to $dest"
    done
fi
